PORT=3000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=1234
# Optional external price source
PRICE_SOURCE_URL=
# Optional custom data directory
DATA_DIR=./data
# Railway'de onerilen deger: ${{RAILWAY_VOLUME_MOUNT_PATH}}

# oBilet bildirim ayarlari
DEFAULT_NOTIF_EMAIL=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
# oBilet takip periyodu (dakika)
OBILET_CHECK_INTERVAL_MINUTES=10
# always: her periyotta rapor maili, changes: sadece degisiklik olursa mail
OBILET_EMAIL_MODE=always
# Mail konu satiri ozellestirme
OBILET_SUBJECT_CHANGE=O bilet fiyat Raporu
OBILET_SUBJECT_NO_CHANGE=O bilet fiyat Raporu
OBILET_SUBJECT_PRICE_ALERT=oBilet Fiyat Degisikligi
OBILET_SUBJECT_TEST=oBilet Test E-postasi

# SMTP bloklanirsa HTTP mail fallback (opsiyonel)
RESEND_API_KEY=
BREVO_API_KEY=
